FLASK_SECRET_KEY=change_me_to_a_long_random_value

# Comma-separated fallback recipients for system alerts.
ALERT_DEFAULT_RECIPIENTS=admin@example.com

# SMTP settings for outbound emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=your_sender_email@example.com
SMTP_SENDER_APP_PASSWORD=your_app_password

